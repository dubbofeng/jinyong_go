# Authentication
AUTH_SECRET=your-auth-secret-here
AUTH_URL=http://localhost:9999

# Database
DATABASE_URL=your-database-url-here

# AI图片生成服务（四选一）

# 方案1: Google Gemini 2.5 Flash Image (推荐，免费配额)
# 获取密钥: https://aistudio.google.com/app/apikey
# 文档: https://ai.google.dev/gemini-api/docs/image-generation
# 特点: 快速高效，1024px分辨率，支持多种宽高比
# GEMINI_API_KEY=AIzaSy...xxxxxxxxxxxxxxxxxxxxx

# 方案2: Stability AI (生产环境推荐，高质量)
# 获取密钥: https://platform.stability.ai/account/keys
# 特点: SDXL模型，速度快，成本约$0.06/10张图
# STABILITY_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx

# 方案3: Hugging Face (免费测试)
# 获取密钥: https://huggingface.co/settings/tokens
# 特点: 完全免费，但速度较慢，首次可能需要冷启动
# HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxx

# 方案4: OpenAI DALL-E 3 (最高质量，较贵)
# 获取密钥: https://platform.openai.com/api-keys
# 特点: 图片质量极高，成本约$0.60/10张图
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx

# 使用说明：
# 1. 取消注释上面四个选项之一（推荐 Gemini - 免费且快速）
# 2. 填入你的API密钥
# 3. 重启开发服务器: pnpm dev
# 4. 访问 http://localhost:9999/zh/admin/assets 开始生成图片
# 5. 系统会自动按优先级选择可用的API（Gemini > HuggingFace > Stability > OpenAI）

