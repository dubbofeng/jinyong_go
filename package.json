{
  "private": true,
  "scripts": {
    "dev": "next dev --turbo -p 9999",
    "build": "next build",
    "start": "next start -p 9999",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "dotenv -e .env.local -- drizzle-kit push",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "db:seed": "dotenv -e .env.local -- tsx src/db/seed.ts",
    "seed": "dotenv -e .env.local -- tsx scripts/seed-data.ts",
    "seed:maps": "dotenv -e .env.local -- tsx scripts/init-maps.ts",
    "seed:all": "pnpm seed && pnpm seed:maps",
    "db:reset": "pnpm db:push && pnpm seed:all",
    "generate:player": "tsx scripts/generate-player-sprite.ts",
    "generate:npcs": "tsx scripts/generate-npc-sprites.ts",
    "generate:sprites-ai": "dotenv -e .env.local -- tsx scripts/generate-sprites-ai.ts",
    "generate:player-spritesheet": "dotenv -e .env.local -- tsx scripts/generate-player-spritesheet.ts",
    "generate:player-walk": "tsx scripts/generate-player-walk-animation.ts",
    "resize:sprites": "tsx scripts/resize-sprites.ts",
    "remove:background": "tsx scripts/remove-background.ts",
    "add:npcs": "dotenv -e .env.local -- tsx scripts/add-npcs-to-map.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@types/node": "^20.10.5",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "bcrypt-ts": "^5.0.0",
    "drizzle-orm": "^0.45.1",
    "geist": "^1.2.0",
    "next": "^14.0.4",
    "next-auth": "5.0.0-beta.4",
    "next-intl": "^4.7.0",
    "noisejs": "^2.1.0",
    "pathfinding": "^0.4.18",
    "postgres": "^3.4.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/pathfinding": "^0.1.0",
    "autoprefixer": "^10.4.16",
    "canvas": "^3.2.1",
    "dotenv": "^17.2.3",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.8",
    "eslint": "8.56.0",
    "eslint-config-next": "^14.0.4",
    "postcss": "^8.4.32",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
}
