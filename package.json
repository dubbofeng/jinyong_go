{
  "private": true,
  "scripts": {
    "dev": "next dev --turbo -p 9999",
    "build": "next build",
    "start": "next start -p 9999",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "check": "pnpm lint && pnpm format:check && pnpm type-check",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "dotenv -e .env.local -- drizzle-kit push",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "db:seed": "dotenv -e .env.local -- tsx src/db/seed.ts",
    "init:npcs": "dotenv -e .env.local -- tsx scripts/init-all-npcs.ts",
    "init:maps": "dotenv -e .env.local -- tsx scripts/init-complete-maps.ts",
    "generate:maps": "dotenv -e .env.local -- tsx scripts/generate-complete-maps.ts && dotenv -e .env.local -- tsx scripts/add-npcs-to-map.ts",
    "seed:maps": "dotenv -e .env.local -- tsx scripts/init-maps.ts",
    "db:reset": "pnpm db:push && pnpm init:npcs && pnpm init:maps",
    "generate:player": "tsx scripts/generate-player-sprite.ts",
    "generate:npcs": "tsx scripts/generate-npc-sprites.ts",
    "remove:background": "tsx scripts/remove-background.ts",
    "test:remove-bg": "tsx scripts/test-remove-background.ts",
    "add:npcs": "dotenv -e .env.local -- tsx scripts/add-npcs-to-map.ts",
    "e2e": "tsx scripts/clear-e2e-users.ts && playwright test",
    "e2e:ui": "tsx scripts/clear-e2e-users.ts && playwright test --ui",
    "e2e:install": "playwright install --with-deps"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@sabaki/sgf": "^3.4.7",
    "@types/node": "^20.10.5",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "bcrypt-ts": "^5.0.0",
    "drizzle-orm": "^0.45.1",
    "geist": "^1.2.0",
    "next": "^14.0.4",
    "next-auth": "5.0.0-beta.4",
    "next-intl": "^4.7.0",
    "noisejs": "^2.1.0",
    "pathfinding": "^0.4.18",
    "postgres": "^3.4.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/pathfinding": "^0.1.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "autoprefixer": "^10.4.16",
    "canvas": "^3.2.1",
    "dotenv": "^17.2.3",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.8",
    "eslint": "8.57.1",
    "eslint-config-next": "^14.0.4",
    "postcss": "^8.4.32",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
}
