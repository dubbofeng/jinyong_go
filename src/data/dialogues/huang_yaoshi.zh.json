{
  "npcId": "huang_yaoshi",
  "npcName": "黄药师",
  "startNodeId": "greeting",
  "nodes": [
    {
      "id": "greeting",
      "speaker": "黄药师",
      "text": "呵呵，又有后生来桃花岛了。你是冲着老夫的名头来的，还是误打误撞？"
    },
    {
      "id": "first_meet",
      "speaker": "黄药师",
      "text": "老夫黄药师，人称东邪。精通奇门遁甲、琴棋书画。听说你在江湖上以棋会友，有点意思。"
    },
    {
      "id": "check_status",
      "speaker": "黄药师",
      "text": "老夫的「奇门遁甲」之术融会贯通，用在围棋上更是变化无穷。不过，你得先证明自己有资格学。",
      "options": [
        {
          "text": "请黄岛主指教！"
        },
        {
          "text": "我想学习「奇门遁甲」"
        },
        {
          "text": "黄岛主，我想再和你对弈一局"
        },
        {"text": "奇门遁甲如何用在围棋上？"},
        {"text": "我还想准备一下"},
        {"text": "请黄岛主讲讲布局"}
      ]
    },
    {
      "id": "explain_skill",
      "speaker": "黄药师",
      "text": "奇门遁甲讲究「变化莫测，出奇制胜」。在棋盘上，能布下玄妙阵法，让对手如入迷阵。"
    },
    {
      "id": "explain_skill_2",
      "speaker": "黄药师",
      "text": "这招能让你在关键时刻改变棋局格局，创造出意想不到的变化。不过，需要极高的悟性才能掌握。",
      "options": [
        {"text": "精妙！请黄岛主教我"},
        {"text": "我再参悟一下"}
      ]
    },
    {
      "id": "sgf_teach_intro",
      "speaker": "黄药师",
      "text": "布局乃棋道之根基，先从经典布局讲起。",
      "options": [
        {"text": "请讲"},
        {"text": "改日再学"}
      ]
    },
    {
      "id": "sgf_route_01",
      "speaker": "黄药师",
      "text": "第一讲：三连星布局 I。",
      "options": [
        {"text": "开始这一讲"},
        {"text": "我已学过，继续下一讲"}
      ]
    },
    {
      "id": "sgf_lesson_01",
      "speaker": "黄药师",
      "text": "看棋谱，感受三连星的气势。"
    },
    {
      "id": "sgf_route_02",
      "speaker": "黄药师",
      "text": "第二讲：三连星布局 II。",
      "options": [
        {"text": "开始这一讲"},
        {"text": "继续下一讲"}
      ]
    },
    {
      "id": "sgf_lesson_02",
      "speaker": "黄药师",
      "text": "第二讲棋谱。"
    },
    {
      "id": "sgf_route_03",
      "speaker": "黄药师",
      "text": "第三讲：中国流 I。",
      "options": [
        {"text": "开始这一讲"},
        {"text": "继续下一讲"}
      ]
    },
    {
      "id": "sgf_lesson_03",
      "speaker": "黄药师",
      "text": "中国流的基本构型。"
    },
    {
      "id": "sgf_route_04",
      "speaker": "黄药师",
      "text": "第四讲：中国流 II。",
      "options": [
        {"text": "开始这一讲"},
        {"text": "继续下一讲"}
      ]
    },
    {
      "id": "sgf_lesson_04",
      "speaker": "黄药师",
      "text": "进一步变化。"
    },
    {
      "id": "sgf_route_05",
      "speaker": "黄药师",
      "text": "第五讲：中国流 III。",
      "options": [
        {"text": "开始这一讲"},
        {"text": "继续下一讲"}
      ]
    },
    {
      "id": "sgf_lesson_05",
      "speaker": "黄药师",
      "text": "连贯的推进。"
    },
    {
      "id": "sgf_route_06",
      "speaker": "黄药师",
      "text": "第六讲：中国流内挂。",
      "options": [
        {"text": "开始这一讲"},
        {"text": "继续下一讲"}
      ]
    },
    {
      "id": "sgf_lesson_06",
      "speaker": "黄药师",
      "text": "内挂处理。"
    },
    {
      "id": "sgf_route_07",
      "speaker": "黄药师",
      "text": "第七讲：中国流定式 I。",
      "options": [
        {"text": "开始这一讲"},
        {"text": "继续下一讲"}
      ]
    },
    {
      "id": "sgf_lesson_07",
      "speaker": "黄药师",
      "text": "定式基础。"
    },
    {
      "id": "sgf_route_08",
      "speaker": "黄药师",
      "text": "第八讲：小林流 I。",
      "options": [
        {"text": "开始这一讲"},
        {"text": "继续下一讲"}
      ]
    },
    {
      "id": "sgf_lesson_08",
      "speaker": "黄药师",
      "text": "小林流布局。"
    },
    {
      "id": "sgf_route_09",
      "speaker": "黄药师",
      "text": "第九讲：迷你中国流 I。",
      "options": [
        {"text": "开始这一讲"},
        {"text": "继续下一讲"}
      ]
    },
    {
      "id": "sgf_lesson_09",
      "speaker": "黄药师",
      "text": "紧凑布局。"
    },
    {
      "id": "sgf_route_10",
      "speaker": "黄药师",
      "text": "第十讲：高中国流 I。",
      "options": [
        {"text": "开始这一讲"},
        {"text": "继续下一讲"}
      ]
    },
    {
      "id": "sgf_lesson_10",
      "speaker": "黄药师",
      "text": "高位展开。"
    },
    {
      "id": "sgf_pattern_intro",
      "speaker": "黄药师",
      "text": "布局之后，再看常型。",
      "options": [
        {"text": "请讲"},
        {"text": "先到这里"}
      ]
    },
    {
      "id": "sgf_route_11",
      "speaker": "黄药师",
      "text": "常型一：星大飞尖。",
      "options": [
        {"text": "开始这一讲"},
        {"text": "继续下一讲"}
      ]
    },
    {
      "id": "sgf_lesson_11",
      "speaker": "黄药师",
      "text": "星大飞尖棋谱。"
    },
    {
      "id": "sgf_route_12",
      "speaker": "黄药师",
      "text": "常型二：星大飞拖。",
      "options": [
        {"text": "开始这一讲"},
        {"text": "继续下一讲"}
      ]
    },
    {
      "id": "sgf_lesson_12",
      "speaker": "黄药师",
      "text": "星大飞拖棋谱。"
    },
    {
      "id": "sgf_route_13",
      "speaker": "黄药师",
      "text": "常型三：星大飞点三三。",
      "options": [
        {"text": "开始这一讲"},
        {"text": "继续下一讲"}
      ]
    },
    {
      "id": "sgf_lesson_13",
      "speaker": "黄药师",
      "text": "点三三变化。"
    },
    {
      "id": "sgf_route_14",
      "speaker": "黄药师",
      "text": "常型四：星大飞玉柱。",
      "options": [
        {"text": "开始这一讲"},
        {"text": "继续下一讲"}
      ]
    },
    {
      "id": "sgf_lesson_14",
      "speaker": "黄药师",
      "text": "玉柱手筋。"
    },
    {
      "id": "sgf_route_15",
      "speaker": "黄药师",
      "text": "常型五：星小飞漏拖。",
      "options": [
        {"text": "开始这一讲"},
        {"text": "继续下一讲"}
      ]
    },
    {
      "id": "sgf_lesson_15",
      "speaker": "黄药师",
      "text": "小飞相关变化。"
    },
    {
      "id": "sgf_route_16",
      "speaker": "黄药师",
      "text": "常型六：星小飞点三三或拆边。",
      "options": [
        {"text": "开始这一讲"},
        {"text": "继续下一讲"}
      ]
    },
    {
      "id": "sgf_lesson_16",
      "speaker": "黄药师",
      "text": "点三三或拆边的取舍。"
    },
    {
      "id": "sgf_all_done",
      "speaker": "黄药师",
      "text": "这些棋谱都看过了，剩下的就要靠你多下多悟。",
      "options": [
        {"text": "多谢黄岛主！"},
        {"text": "我还想听听您的见解"}
      ]
    },
    {
      "id": "challenge_intro",
      "speaker": "黄药师",
      "text": "好！有胆识！老夫生平最讨厌迂腐之人，你这股闯劲倒是合老夫胃口。"
    },
    {
      "id": "challenge_condition",
      "speaker": "黄药师",
      "text": "老夫当年华山论剑，与洪七公、欧阳锋对弈，各有千秋。你若能在棋盘上赢老夫，就算你有真本事。",
      "options": [
        {
          "text": "请黄岛主赐教！"
        },
        {"text": "我先准备一下"}
      ]
    },
    {
      "id": "start_battle",
      "speaker": "黄药师",
      "text": "哈哈，那就来吧！让你见识见识东邪的厉害！"
    },
    {
      "id": "teach_skill",
      "speaker": "黄药师",
      "text": "不错不错！后生可畏！你这棋下得天马行空，颇有老夫当年的风采。好，老夫就传你「奇门遁甲」。"
    },
    {
      "id": "teach_skill_detail",
      "speaker": "黄药师",
      "text": "这招的要领是：运用奇门遁甲之理，在棋盘上布下玄妙阵法，让对手陷入困局。每局可用一次，冷却35步。"
    },
    {
      "id": "teach_complete",
      "speaker": "黄药师",
      "text": "对了，老夫那女儿蓉儿在襄阳。你去找她时，替老夫问个好。她的「机关算尽」也是老夫教的。",
      "options": [
        {"text": "多谢黄岛主！"},
        {"text": "我还想听听您的见解"},
        {"text": "我想再挑战一次"}
      ]
    },
    {
      "id": "try_again",
      "speaker": "黄药师",
      "text": "棋力还差点火候。不过也不错了，再多练练，别让老夫失望。",
      "options": [
        {"text": "晚辈告退"},
        {"text": "我再挑战一次！"}
      ]
    },
    {
      "id": "daily_chat",
      "speaker": "黄药师",
      "text": "老夫一生不羁，只求逍遥自在。这世间俗礼，对老夫来说都是枷锁。下棋也是一样，要破除成见。"
    },
    {
      "id": "daily_chat_2",
      "speaker": "黄药师",
      "text": "不过，老夫虽是「东邪」，但从不做伤天害理之事。棋如人品，这一点你要记住。",
      "options": [
        {"text": "黄岛主高风亮节！"}
      ]
    },
    {
      "id": "not_ready",
      "speaker": "黄药师",
      "text": "也罢，准备好了再来。桃花岛就在这里，老夫随时恭候。"
    },
    {
      "id": "farewell",
      "speaker": "黄药师",
      "text": "哈哈，后生好好努力！期待你日后能在棋道上有所成就！"
    }
  ]
}
