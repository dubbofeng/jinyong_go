{
  "npcId": "murong_fu",
  "npcName": "慕容复",
  "startNodeId": "greeting",
  "nodes": [
    {
      "id": "greeting",
      "speaker": "慕容复",
      "text": "哼，又是一个不知天高地厚的人。在下慕容复，姑苏慕容氏。你来此何事？",
      "nextNodeId": "first_meet"
    },
    {
      "id": "first_meet",
      "speaker": "慕容复",
      "text": "在下当年也曾挑战珍珑棋局，虽未能破解，但也有所收获。你也是为了那棋局而来？",
      "nextNodeId": "check_status"
    },
    {
      "id": "check_status",
      "speaker": "慕容复",
      "text": "在下慕容家有一套「以彼之道，还施彼身」的绝学。这招用在围棋上，能将对手的招数反制回去。",
      "options": [
        {
          "text": "请慕容公子指教！",
          "condition": {"type": "quest", "value": "defeated_murong_fu", "inverse": true},
          "nextNodeId": "challenge_intro"
        },
        {
          "text": "我想学习「以彼之道，还施彼身」",
          "condition": {"type": "quest", "value": "defeated_murong_fu"},
          "nextNodeId": "teach_skill"
        },
        {
          "text": "慕容公子，我想再和你对弈一局",
          "condition": {"type": "quest", "value": "defeated_murong_fu"},
          "action": {"type": "battle", "value": "murong_fu"},
          "nextNodeId": "start_battle"
        },
        {"text": "这招如何用在围棋上？", "nextNodeId": "explain_skill"},
        {"text": "我还想准备一下", "nextNodeId": "not_ready"}
      ]
    },
    {
      "id": "explain_skill",
      "speaker": "慕容复",
      "text": "姑苏慕容氏的「以彼之道，还施彼身」，能将对手的招数反制回去，让他自食其果。",
      "nextNodeId": "explain_skill_2"
    },
    {
      "id": "explain_skill_2",
      "speaker": "慕容复",
      "text": "用在棋局上，就是能识破对手的棋路，然后用同样的方式反击，让他陷入自己设下的陷阱。",
      "options": [
        {"text": "高明！请慕容公子教我", "nextNodeId": "challenge_intro"},
        {"text": "我再考虑考虑", "nextNodeId": "not_ready"}
      ]
    },
    {
      "id": "challenge_intro",
      "speaker": "慕容复",
      "text": "好。不过在下这套绝学，不是谁都能学的。你要想学，得先证明自己有这个资格。",
      "nextNodeId": "challenge_condition"
    },
    {
      "id": "challenge_condition",
      "speaker": "慕容复",
      "text": "在下虽然未能破解珍珑，但棋力也不容小觑。你若能胜在下，就说明你有这个资质。",
      "options": [
        {
          "text": "请慕容公子赐教！",
          "action": {"type": "battle", "value": "murong_fu"},
          "nextNodeId": "start_battle"
        },
        {"text": "我先准备一下", "nextNodeId": "not_ready"}
      ]
    },
    {
      "id": "start_battle",
      "speaker": "慕容复",
      "text": "哼！那就让你见识见识姑苏慕容的厉害！"
    },
    {
      "id": "teach_skill",
      "speaker": "慕容复",
      "text": "不错...你这棋下得确实有水平。也罢，在下就传你「以彼之道，还施彼身」。",
      "nextNodeId": "teach_skill_detail"
    },
    {
      "id": "teach_skill_detail",
      "speaker": "慕容复",
      "text": "这招的要领是：识破对手的棋路，然后用同样的方式反击。每局限用一次，冷却45步。",
      "nextNodeId": "teach_skill_practice"
    },
    {
      "id": "teach_skill_practice",
      "speaker": "慕容复",
      "text": "记住，用此招时要「知己知彼，百战不殆」。只有完全了解对手，才能将他的招数反制回去。",
      "action": {"type": "skill", "value": {"skillId": "yibi_zhidao", "questId": "quest_020_murong_fu"}},
      "nextNodeId": "teach_complete"
    },
    {
      "id": "teach_complete",
      "speaker": "慕容复",
      "text": "你既然学了这招，以后遇到强敌也有应对之策。不过要记住，复国大业才是最重要的。",
      "options": [
        {"text": "多谢慕容公子！", "nextNodeId": "farewell"},
        {"text": "我还想听听您的见解", "nextNodeId": "daily_chat"},
        {"text": "我想再挑战一次", "action": {"type": "battle", "value": "murong_fu"}, "nextNodeId": "start_battle"}
      ]
    },
    {
      "id": "try_again",
      "speaker": "慕容复",
      "text": "哼，你的水平还不够。再去练练，别浪费在下的时间。",
      "options": [
        {"text": "在下告退", "nextNodeId": "farewell"},
        {"text": "我再挑战一次！", "nextNodeId": "challenge_condition"}
      ]
    },
    {
      "id": "daily_chat",
      "speaker": "慕容复",
      "text": "在下这一生只有一个目标，那就是复兴大燕。为了这个目标，在下可以付出一切。",
      "nextNodeId": "daily_chat_2"
    },
    {
      "id": "daily_chat_2",
      "speaker": "慕容复",
      "text": "下棋也是一样，要有明确的目标，然后全力以赴。没有目标的人，永远不会成功。",
      "options": [
        {"text": "慕容公子志向远大！", "nextNodeId": "farewell"}
      ]
    },
    {
      "id": "not_ready",
      "speaker": "慕容复",
      "text": "哼，准备好了再来。在下可没时间等你。"
    },
    {
      "id": "farewell",
      "speaker": "慕容复",
      "text": "走吧。在下还有要事在身。"
    }
  ]
}
