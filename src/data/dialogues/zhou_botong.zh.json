    {
      "id": "teach_skill_practice",
      "speaker": "周伯通",
      "text": "记住哦，用这招的时候要「左手画圆，右手画方」，不能乱！老顽童我练了好久才学会呢！",
      "action": {"type": "skill", "value": {"skillId": "zuoyou_hubo", "questId": "quest_015_zhou_botong"}},
      "nextNodeId": "teach_complete"
