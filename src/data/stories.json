        "triggerCondition": "chapter_start",
        "dialogues": [
          {
            "speaker": "木桑道长",
            "speakerId": "mu_sang",
            "text": "小友，这局棋名为'千变万劫'，乃是我平生所遇最精妙的一局。当年在华山之巅，我与西域高僧对弈七日七夜……",
            "emotion": "thoughtful"
          },
          {
            "speaker": "你",
            "speakerId": "player",
            "text": "（看着棋盘）这黑白交错之间，似乎蕴含着无穷变化……",
            "emotion": "curious"
          },
          {
            "speaker": "木桑道长",
            "speakerId": "mu_sang",
            "text": "正是如此。围棋之道，与武学修为息息相关。棋力高者，内功深厚；棋艺精湛者，招式灵活多变。",
            "emotion": "serious"
          },
          {
            "speaker": "木桑道长",
            "speakerId": "mu_sang",
            "text": "来，让老道看看你的棋力几何。",
            "emotion": "challenging"
          }
        ],
        "rewards": {
          "exp": 100,
