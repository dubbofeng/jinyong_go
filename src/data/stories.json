[
  {
    "storyId": "story_musang_daoren",
    "title": "千变万劫",
    "titleEn": "Infinite Variations",
    "npcIds": ["musang_daoren"],
    "trigger": "first_click",
    "scenes": [
      {
        "sceneId": "musang_01",
        "backgroundId": "story_musang_pine_courtyard",
        "lines": [
          { "type": "narration", "text": "松影斑驳的山道旁，木桑道人背着棋盘，笑意满面。" },
          { "type": "dialogue", "speaker": "木桑道人", "speakerId": "musang_daoren", "text": "小友，棋盘随身，世上便不怕无弈友。" },
          { "type": "dialogue", "speaker": "你", "speakerId": "player", "text": "道长好兴致。听说你有一盘名局？" },
          { "type": "dialogue", "speaker": "木桑道人", "speakerId": "musang_daoren", "text": "人称“千变万劫”。棋势如江海，牵一子动全局。" },
          { "type": "narration", "text": "他一面布子，一面说起山中清修与棋道相通之理。" },
          { "type": "dialogue", "speaker": "木桑道人", "speakerId": "musang_daoren", "text": "武学讲究气脉，棋局讲究气口。都要看远、算深。" },
          { "type": "dialogue", "speaker": "你", "speakerId": "player", "text": "若是心乱，棋也乱。" },
          { "type": "dialogue", "speaker": "木桑道人", "speakerId": "musang_daoren", "text": "说得好。棋有生死，亦有取舍。" },
          { "type": "narration", "text": "他忽然把一颗黑子按在险处，像是试探命运。" },
          { "type": "dialogue", "speaker": "木桑道人", "speakerId": "musang_daoren", "text": "老道不久要远行，此局便当一卦。" },
          { "type": "dialogue", "speaker": "你", "speakerId": "player", "text": "远行之事，可愿详说？" },
          { "type": "dialogue", "speaker": "木桑道人", "speakerId": "musang_daoren", "text": "为一件师门遗物。先机一失，便再难追。" }
        ]
      },
      {
        "sceneId": "musang_02",
        "backgroundId": "story_musang_taoist_room",
        "lines": [
          { "type": "narration", "text": "烛影摇曳，他的脸在光影中忽明忽暗。" },
          { "type": "dialogue", "speaker": "木桑道人", "speakerId": "musang_daoren", "text": "这片黑子，就像我此行，步步凶险。" },
          { "type": "dialogue", "speaker": "你", "speakerId": "player", "text": "可否先稳住一隅，再图他处？" },
          { "type": "dialogue", "speaker": "木桑道人", "speakerId": "musang_daoren", "text": "嗯……退一步，未必是退。" },
          { "type": "narration", "text": "你转身在远角落子，腾出眼位。" },
          { "type": "dialogue", "speaker": "木桑道人", "speakerId": "musang_daoren", "text": "妙着！此局可活。" },
          { "type": "dialogue", "speaker": "你", "speakerId": "player", "text": "胜负之外，只求心安。" },
          { "type": "dialogue", "speaker": "木桑道人", "speakerId": "musang_daoren", "text": "老道自吹也好，今日却是真的开心。" },
          { "type": "narration", "text": "他把棋子收好，神色轻快了许多。" },
          { "type": "dialogue", "speaker": "木桑道人", "speakerId": "musang_daoren", "text": "这份棋谱赠你，记下今日心境。" }
        ],
        "choices": [
          {
            "choiceId": "musang_reward_talisman",
            "text": "收下棋谱与护符",
            "rewards": {
              "exp": 120,
              "silver": 80,
              "items": [
                { "itemId": "item_story_go_manual", "name": "棋道手札", "description": "记录木桑道人心得，阅读后获得围棋灵感。", "quantity": 1 },
                { "itemId": "item_story_talisman", "name": "山行护符", "description": "山中求安的护身符，小幅提升体力恢复。", "quantity": 1 }
              ]
            }
          },
          {
            "choiceId": "musang_reward_tea",
            "text": "只取清茶与碎银",
            "rewards": {
              "exp": 120,
              "silver": 120,
              "items": [
                { "itemId": "item_story_pine_tea", "name": "松针清茶", "description": "山中清茶，饮用后恢复少量内力。", "quantity": 1 }
              ]
            }
          }
        ]
      }
    ]
  },
  {
    "storyId": "story_wanjie_duel",
    "title": "万劫谷石局",
    "titleEn": "Stone Board at Wanjie Valley",
    "npcIds": ["huangmei_seng", "duan_yanqing"],
    "trigger": "first_click",
    "scenes": [
      {
        "sceneId": "wanjie_00",
        "backgroundId": "story_wanjie_stone_board",
        "lines": [
          { "type": "narration", "text": "万劫谷石屋内，石屑纷飞，一张十九道棋盘在青石上刻成。" },
          { "type": "dialogue", "speaker": "黄眉僧", "speakerId": "huangmei_seng", "text": "段施主，棋局定胜负，可敢一局？" },
          { "type": "dialogue", "speaker": "段延庆", "speakerId": "duan_yanqing", "text": "金刚指力，好功夫！" },
          { "type": "narration", "text": "铁杖与木槌在石上留下深痕，黑白势子落定。" },
          { "type": "dialogue", "speaker": "黄眉僧", "speakerId": "huangmei_seng", "text": "施主功力深厚，老僧不敢逞强，还望让上几子。" },
          { "type": "dialogue", "speaker": "段延庆", "speakerId": "duan_yanqing", "text": "棋上要分胜负，便当平下。" },
          { "type": "dialogue", "speaker": "黄眉僧", "speakerId": "huangmei_seng", "text": "四子如何？三子也可。" },
          { "type": "dialogue", "speaker": "段延庆", "speakerId": "duan_yanqing", "text": "既自认不及，何必再局？最多让一先。" },
          { "type": "dialogue", "speaker": "黄眉僧", "speakerId": "huangmei_seng", "text": "哈哈，原来施主棋力也不过如此，不妨我让你三子。" },
          { "type": "dialogue", "speaker": "段延庆", "speakerId": "duan_yanqing", "text": "不必相让，分先对弈。" },
          { "type": "narration", "text": "黄眉僧心下愈发忌惮，暗知此人不骄不躁，难以激怒。" }
        ]
      },
      {
        "sceneId": "wanjie_01",
        "backgroundId": "story_wanjie_toe_riddle",
        "lines": [
          { "type": "dialogue", "speaker": "黄眉僧", "speakerId": "huangmei_seng", "text": "先后之争，便赌一线气运。" },
          { "type": "dialogue", "speaker": "段延庆", "speakerId": "duan_yanqing", "text": "你想争先手，便使出你的本事。" },
          { "type": "dialogue", "speaker": "黄眉僧", "speakerId": "huangmei_seng", "text": "先手关乎生死，施主可敢一赌？" },
          { "type": "dialogue", "speaker": "段延庆", "speakerId": "duan_yanqing", "text": "赌什么？" },
          { "type": "dialogue", "speaker": "黄眉僧", "speakerId": "huangmei_seng", "text": "猜我年过七十时，足趾是奇是偶。" },
          { "type": "narration", "text": "段延庆暗自思量，仍答“偶”。" },
          { "type": "dialogue", "speaker": "段延庆", "speakerId": "duan_yanqing", "text": "偶数。" },
          { "type": "narration", "text": "黄眉僧笑而不语，除靴验足，竟两足完好无缺。" },
          { "type": "narration", "text": "他忽提小铁槌，断下一趾，血珠溅在石面。" },
          { "type": "dialogue", "speaker": "黄眉僧", "speakerId": "huangmei_seng", "text": "今我六十九，待七十，足趾成奇。" },
          { "type": "dialogue", "speaker": "段延庆", "speakerId": "duan_yanqing", "text": "好。先手归你。" },
          { "type": "narration", "text": "先手既定，局势更添肃杀。" },
          { "type": "dialogue", "speaker": "黄眉僧", "speakerId": "huangmei_seng", "text": "今日一子之先，关乎万民命数。" },
          { "type": "dialogue", "speaker": "段延庆", "speakerId": "duan_yanqing", "text": "命数？我只信胜负。" },
          { "type": "narration", "text": "棋势如剑，针锋相对。" }
        ]
      },
      {
        "sceneId": "wanjie_02",
        "backgroundId": "story_wanjie_stone_chamber",
        "lines": [
          { "type": "narration", "text": "棋局中盘，黑子突变，白势摇摇欲坠。" },
          { "type": "dialogue", "speaker": "段誉", "speakerId": "duan_yu", "text": "（低声）这一手若不变，怕要失先。" },
          { "type": "dialogue", "speaker": "黄眉僧", "speakerId": "huangmei_seng", "text": "施主既有见，老僧愿从。" },
          { "type": "dialogue", "speaker": "段延庆", "speakerId": "duan_yanqing", "text": "旁观不语才像君子，多管闲事才是真胆。" },
          { "type": "dialogue", "speaker": "段誉", "speakerId": "duan_yu", "text": "你困我在此，我又怎能沉默？" },
          { "type": "narration", "text": "破嗔在背上写下七手，白子一度转危为安。" },
          { "type": "dialogue", "speaker": "黄眉僧", "speakerId": "huangmei_seng", "text": "棋在心中，气在指上。" },
          { "type": "dialogue", "speaker": "段延庆", "speakerId": "duan_yanqing", "text": "好招。可惜，你终要露出破绽。" },
          { "type": "narration", "text": "黑子忽然弃势夺要，白棋一时难解。" },
          { "type": "dialogue", "speaker": "段誉", "speakerId": "duan_yu", "text": "若换此手，可借劫转势。" },
          { "type": "dialogue", "speaker": "黄眉僧", "speakerId": "huangmei_seng", "text": "老僧再赌一线。" },
          { "type": "narration", "text": "铁杖失势，一子成了败笔，段延庆怒碎棋盘。" },
          { "type": "dialogue", "speaker": "段延庆", "speakerId": "duan_yanqing", "text": "此局不算完，天机终会翻转。" }
        ],
        "choices": [
          {
            "choiceId": "wanjie_reward_huangmei",
            "text": "帮黄眉僧稳局",
            "rewards": {
              "exp": 180,
              "silver": 120,
              "items": [
                { "itemId": "item_story_monk_blessing", "name": "禅定香囊", "description": "佛门静心之物，小幅提升内力恢复。", "quantity": 1 }
              ]
            }
          },
          {
            "choiceId": "wanjie_reward_duan",
            "text": "帮段延庆破局",
            "rewards": {
              "exp": 180,
              "silver": 120,
              "items": [
                { "itemId": "item_story_iron_staff_token", "name": "铁杖印记", "description": "暗示段延庆记下你的援手，战斗银两奖励略增。", "quantity": 1 }
              ]
            }
          }
        ]
      }
    ]
  },
  {
    "storyId": "story_chen_jialuo",
    "title": "壁上飞子",
    "titleEn": "Stones on the Wall",
    "npcIds": ["chen_jialuo"],
    "trigger": "first_click",
    "scenes": [
      {
        "sceneId": "chen_01",
        "backgroundId": "story_haining_wall_board",
        "lines": [
          { "type": "narration", "text": "后院，一面墙竟刻成棋盘，棋子嵌入石道。" },
          { "type": "dialogue", "speaker": "陈家洛", "speakerId": "chen_jialuo", "text": "此局不用手落子，用腕与劲。" },
          { "type": "dialogue", "speaker": "你", "speakerId": "player", "text": "把棋子当暗器？" },
          { "type": "dialogue", "speaker": "陈家洛", "speakerId": "chen_jialuo", "text": "棋为器，心为势。若势先到，子自会中。" },
          { "type": "narration", "text": "黑子飞出，嵌入棋道，劲风卷起尘屑。" },
          { "type": "dialogue", "speaker": "庄客", "speakerId": "npc", "text": "好准的手劲！" },
          { "type": "dialogue", "speaker": "陈家洛", "speakerId": "chen_jialuo", "text": "准不准，要看对手如何守。" },
          { "type": "dialogue", "speaker": "你", "speakerId": "player", "text": "棋局若失先机，如何补救？" },
          { "type": "dialogue", "speaker": "陈家洛", "speakerId": "chen_jialuo", "text": "破阵不靠守，靠变。" },
          { "type": "narration", "text": "白子一投，略偏半寸，局势忽然倒转。" }
        ]
      },
      {
        "sceneId": "chen_02",
        "backgroundId": "story_haining_throwing_stones",
        "lines": [
          { "type": "dialogue", "speaker": "陈家洛", "speakerId": "chen_jialuo", "text": "你看，棋子偏了，便是破绽。" },
          { "type": "dialogue", "speaker": "你", "speakerId": "player", "text": "所以要稳住心手。" },
          { "type": "dialogue", "speaker": "陈家洛", "speakerId": "chen_jialuo", "text": "也要敢于乱。乱中求胜，才是暗器之道。" },
          { "type": "narration", "text": "他示范将一颗黑子打歪，落在意想不到的点位。" },
          { "type": "dialogue", "speaker": "陈家洛", "speakerId": "chen_jialuo", "text": "此招名为棋子暗器，扰乱对手心神。" },
          { "type": "dialogue", "speaker": "你", "speakerId": "player", "text": "乱中不失其道，才是真本事。" },
          { "type": "narration", "text": "他收手一笑，将一小袋石子递到你手里。" }
        ],
        "choices": [
          {
            "choiceId": "chen_reward_precision",
            "text": "学习稳准之法",
            "rewards": {
              "exp": 140,
              "silver": 100,
              "items": [
                { "itemId": "item_story_weighted_stone", "name": "定手石", "description": "练习手腕稳定的石子，提升暗器命中率，可将棋子暗器技能提升一个等级。", "quantity": 1 }
              ]
            }
          },
          {
            "choiceId": "chen_reward_chaos",
            "text": "学习乱中求变",
            "rewards": {
              "exp": 140,
              "silver": 100,
              "items": [
                { "itemId": "item_story_scatter_pouch", "name": "散势袋", "description": "乱局之物，使用后减少一次技能冷却。", "quantity": 1 }
              ]
            }
          }
        ]
      }
    ]
  },
  {
    "storyId": "story_he_zudao",
    "title": "琴棋剑三圣",
    "titleEn": "The Three Saints",
    "npcIds": ["he_zudao"],
    "trigger": "first_click",
    "scenes": [
      {
        "sceneId": "he_01",
        "backgroundId": "story_kunlun_sands",
        "lines": [
          { "type": "narration", "text": "昆仑空地上，何足道以剑尖划地，横纵十九道渐成棋盘。" },
          { "type": "dialogue", "speaker": "何足道", "speakerId": "he_zudao", "text": "琴可入心，剑可入骨，唯棋可入魂。" },
          { "type": "dialogue", "speaker": "你", "speakerId": "player", "text": "无人对弈，竟自与己争？" },
          { "type": "dialogue", "speaker": "何足道", "speakerId": "he_zudao", "text": "世上无我之敌，便让心与心为敌。" },
          { "type": "narration", "text": "黑白两势在左上角缠斗，剑气与风声交织。" },
          { "type": "dialogue", "speaker": "郭襄", "speakerId": "npc", "text": "此势若恋中腹，恐要全军覆没。" },
          { "type": "dialogue", "speaker": "你", "speakerId": "player", "text": "不如弃中取边？" },
          { "type": "dialogue", "speaker": "何足道", "speakerId": "he_zudao", "text": "弃一处，换一局。" }
        ]
      },
      {
        "sceneId": "he_02",
        "backgroundId": "story_kunlun_sword_board",
        "lines": [
          { "type": "narration", "text": "他大笑数声，转向西侧空地连下两子，势态顿转。" },
          { "type": "dialogue", "speaker": "何足道", "speakerId": "he_zudao", "text": "好！好！局面既破，心境自开。" },
          { "type": "dialogue", "speaker": "你", "speakerId": "player", "text": "这便是弃子取势。" },
          { "type": "dialogue", "speaker": "何足道", "speakerId": "he_zudao", "text": "世事亦然。" },
          { "type": "narration", "text": "他收剑而立，神色舒朗。" }
        ],
        "choices": [
          {
            "choiceId": "he_reward_qin",
            "text": "学琴意静心",
            "rewards": {
              "exp": 130,
              "silver": 90,
              "items": [
                { "itemId": "item_story_calm_chord", "name": "清弦谱", "description": "琴谱一页，提升内力恢复效率。", "quantity": 1 }
              ]
            }
          },
          {
            "choiceId": "he_reward_jian",
            "text": "学剑意决断",
            "rewards": {
              "exp": 130,
              "silver": 90,
              "items": [
                { "itemId": "item_story_edge_charm", "name": "决断符", "description": "提升一次技能使用上限提示。", "quantity": 1 }
              ]
            }
          }
        ]
      }
    ]
  },
  {
    "storyId": "story_hei_baizi",
    "title": "呕血谱一着",
    "titleEn": "The Vomiting Blood Manual",
    "npcIds": ["hei_baizi"],
    "trigger": "first_click",
    "scenes": [
      {
        "sceneId": "hei_01",
        "backgroundId": "story_meizhuang_study",
        "lines": [
          { "type": "narration", "text": "梅庄密室里，古谱摊开，黑白子额上微汗。" },
          { "type": "dialogue", "speaker": "黑白子", "speakerId": "hei_baizi", "text": "此谱名为《呕血谱》，我思索多年。" },
          { "type": "dialogue", "speaker": "你", "speakerId": "player", "text": "何处最难？" },
          { "type": "dialogue", "speaker": "黑白子", "speakerId": "hei_baizi", "text": "第六十七手，断不稳，连不活，冲也冲不出。" },
          { "type": "narration", "text": "他指尖敲在石几上，节奏愈急。" },
          { "type": "dialogue", "speaker": "黑白子", "speakerId": "hei_baizi", "text": "若你是我，会如何落子？" },
          { "type": "dialogue", "speaker": "你", "speakerId": "player", "text": "也许要用缓手，让对方自乱。" },
          { "type": "dialogue", "speaker": "黑白子", "speakerId": "hei_baizi", "text": "妙，就在此处。" }
        ]
      },
      {
        "sceneId": "hei_02",
        "backgroundId": "story_meizhuang_board_close",
        "lines": [
          { "type": "narration", "text": "他落子于上部要点，局面顿现生机。" },
          { "type": "dialogue", "speaker": "黑白子", "speakerId": "hei_baizi", "text": "好！这一步果然妙。" },
          { "type": "dialogue", "speaker": "你", "speakerId": "player", "text": "古谱之妙，在于心静。" },
          { "type": "dialogue", "speaker": "黑白子", "speakerId": "hei_baizi", "text": "心静一分，棋力便进一分。" },
          { "type": "narration", "text": "他将古谱拓印递给你。" }
        ],
        "choices": [
          {
            "choiceId": "hei_reward_rubbing",
            "text": "收下拓本",
            "rewards": {
              "exp": 150,
              "silver": 110,
              "items": [
                { "itemId": "item_story_blood_manual", "name": "呕血谱拓本", "description": "一份棋谱拓印，可用于研究任务。", "quantity": 1 }
              ]
            }
          },
          {
            "choiceId": "hei_reward_ink",
            "text": "换取墨石",
            "rewards": {
              "exp": 150,
              "silver": 110,
              "items": [
                { "itemId": "item_story_inkstone", "name": "静心墨石", "description": "能让思路更清晰的小道具。", "quantity": 1 }
              ]
            }
          }
        ]
      }
    ]
  },
  {
    "storyId": "story_zhenlong",
    "title": "珍珑局心魔",
    "titleEn": "The Zhenlong Puzzle",
    "npcIds": ["xu_zhu"],
    "trigger": "first_click",
    "scenes": [
      {
        "sceneId": "zhenlong_01_duanyu",
        "backgroundId": "story_zhenlong_duanyu",
        "lines": [
          { "type": "narration", "text": "擂鼓山石台前，珍珑棋局布成，黑白势子纠缠成网。" },
          { "type": "dialogue", "speaker": "苏星河", "speakerId": "npc", "text": "此局高处多，落子须断舍。" },
          { "type": "dialogue", "speaker": "段誉", "speakerId": "duan_yu", "text": "我看得见上方生机，却舍不得这一片。" },
          { "type": "narration", "text": "他连下十余手，处处求稳，局势仍被牵制。" },
          { "type": "dialogue", "speaker": "段誉", "speakerId": "duan_yu", "text": "若再弃子，怕一退千里。" },
          { "type": "dialogue", "speaker": "你", "speakerId": "player", "text": "惜子过深，反被局势拖住。" },
          { "type": "dialogue", "speaker": "苏星河", "speakerId": "npc", "text": "能见高处已不易，未敢取舍，便难破局。" }
        ]
      },
      {
        "sceneId": "zhenlong_02_fanbailing",
        "backgroundId": "story_zhenlong_fanbailing",
        "lines": [
          { "type": "narration", "text": "范百龄伏身细算，指尖在棋盘上不停点算。" },
          { "type": "dialogue", "speaker": "范百龄", "speakerId": "npc", "text": "这一劫可解，只差一口气……" },
          { "type": "dialogue", "speaker": "苏星河", "speakerId": "npc", "text": "局非一隅可解，莫只顾局部。" },
          { "type": "narration", "text": "他再算数手，胸口发闷，气血翻涌。" },
          { "type": "dialogue", "speaker": "范百龄", "speakerId": "npc", "text": "再想一步，再想一步……" },
          { "type": "dialogue", "speaker": "丁春秋", "speakerId": "npc", "text": "强行推演，只会反伤自身。" }
        ]
      },
      {
        "sceneId": "zhenlong_03_murongfu",
        "backgroundId": "story_zhenlong_murongfu",
        "lines": [
          { "type": "narration", "text": "慕容复凝视边角，执意以小胜换大势。" },
          { "type": "dialogue", "speaker": "慕容复", "speakerId": "murong_fu", "text": "边角若得，腹地自开。" },
          { "type": "dialogue", "speaker": "你", "speakerId": "player", "text": "只取边角，恐腹心空虚。" },
          { "type": "dialogue", "speaker": "慕容复", "speakerId": "murong_fu", "text": "胜负在此一线，我绝不能失。" },
          { "type": "narration", "text": "他步步计较得失，心态被胜负牵动，落子愈发急促。" }
        ]
      },
      {
        "sceneId": "zhenlong_04_jiumozhi",
        "backgroundId": "story_zhenlong_jiumozhi",
        "lines": [
          { "type": "narration", "text": "鸠摩智绕局而行，目光越过局部，直看大势。" },
          { "type": "dialogue", "speaker": "鸠摩智", "speakerId": "npc", "text": "此局如江河山岳，格局不小。" },
          { "type": "dialogue", "speaker": "你", "speakerId": "player", "text": "大师不入局？" },
          { "type": "dialogue", "speaker": "鸠摩智", "speakerId": "npc", "text": "心不在棋，入局反成累赘。" },
          { "type": "dialogue", "speaker": "鸠摩智", "speakerId": "npc", "text": "看大势易，解细处难，何必徒耗心神。" }
        ]
      },
      {
        "sceneId": "zhenlong_05_duanyanqing",
        "backgroundId": "story_zhenlong_duanyanqing",
        "lines": [
          { "type": "narration", "text": "段延庆以铁杖点子入局，思路强硬，步步逼迫。" },
          { "type": "dialogue", "speaker": "段延庆", "speakerId": "duan_yanqing", "text": "正道偏不得，偏道亦难成。" },
          { "type": "dialogue", "speaker": "丁春秋", "speakerId": "npc", "text": "由正入邪易，回头难。" },
          { "type": "dialogue", "speaker": "段延庆", "speakerId": "duan_yanqing", "text": "棋上只信胜负分明。" },
          { "type": "narration", "text": "他愈走愈偏，执念成形，局势难以回正。" }
        ]
      },
      {
        "sceneId": "zhenlong_06_xuzhu",
        "backgroundId": "story_zhenlong_xuzhu",
        "lines": [
          { "type": "dialogue", "speaker": "虚竹", "speakerId": "xu_zhu", "text": "我不善棋，只愿不负本心。" },
          { "type": "narration", "text": "他闭目落子，自断一块，局面却豁然开朗。" },
          { "type": "dialogue", "speaker": "苏星河", "speakerId": "npc", "text": "此着自杀，岂有此理！" },
          { "type": "dialogue", "speaker": "虚竹", "speakerId": "xu_zhu", "text": "我只是随缘一手。" },
          { "type": "narration", "text": "他惶然无措之际，耳畔忽有细声指点方位。" },
          { "type": "dialogue", "speaker": "神秘声音", "speakerId": "npc", "text": "去位、平位、上位皆可破势，落子莫疑。" },
          { "type": "narration", "text": "虚竹依言落子，局面连转，众人惊叹。" },
          { "type": "dialogue", "speaker": "段延庆", "speakerId": "duan_yanqing", "text": "不必追问来路，先稳住棋势。" },
          { "type": "narration", "text": "旁人听不见传音，虚竹只觉有高人暗中相助。" },
          { "type": "narration", "text": "数着之后，局面忽然大变，段延庆这才明白此局秘奥在于先让白棋自断大块，再由后续妙手翻转。" },
          { "type": "narration", "text": "棋中本有反扑、倒脱靴等弃子之法，但常理只舍少数子力，从未有人敢一口气送出数十子。" },
          { "type": "narration", "text": "这等“挤死自己”的奇变，几乎不在高手常识之内；人皆求生脱困，少有人肯先走入绝路。" },
          { "type": "narration", "text": "若非虚竹闭目误落此手，这一局恐怕再久也无人能解。" }
        ]
      },
      {
        "sceneId": "zhenlong_07_wuyazi",
        "backgroundId": "story_zhenlong_wuyazi",
        "lines": [
          { "type": "narration", "text": "珍珑局破，石室幽深处传来低沉回应。" },
          { "type": "dialogue", "speaker": "无崖子", "speakerId": "npc", "text": "破局者可入，传我真意。" },
          { "type": "dialogue", "speaker": "虚竹", "speakerId": "xu_zhu", "text": "弟子惶恐，只是误打误撞。" },
          { "type": "narration", "text": "无崖子以真气相引，传功入脉，虚竹周身气息顿变。" },
          { "type": "dialogue", "speaker": "无崖子", "speakerId": "npc", "text": "不执胜负，方得逍遥。" },
          { "type": "dialogue", "speaker": "苏星河", "speakerId": "npc", "text": "师命已成，珍珑局今日终解。" }
        ],
        "choices": [
